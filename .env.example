# App Settings
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_PORT=8000

# Database Settings (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mis_eventos
POSTGRES_PORT=5432

# Redis Settings
REDIS_PORT=6379

# Full Database URL (Optional, will be constructed in docker-compose)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mis_eventos
